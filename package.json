  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.78.0",
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "typebox": "^1.1.39"
  },
  "devDependencies": {
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
